import streamlit as st
import requests

st.title("🚌 SmartBus AI - Bus Recommendation System")

source = st.text_input("Enter Source")
destination = st.text_input("Enter Destination")

if st.button("Find Bus"):

    data = {
        "source": source,
        "destination": destination
    }

    response = requests.post(
        "http://127.0.0.1:8000/recommend",
        json=data
    )

    result = response.json()

    st.success(f"Recommended Bus: {result['bus']}")
    st.write(f"Estimated Arrival Time: {result['eta']} minutes")
    st.write(f"Crowd Level: {result['crowd']}")
